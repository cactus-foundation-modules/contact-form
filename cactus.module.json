{
  "name": "contact-form",
  "version": "0.1.25",
  "tablePrefix": "cf_",
  "description": "A contact form that can be placed on any page via the Puck page builder, with per-form settings and an admin inbox.",
  "permissions": [
    "contact.view",
    "contact.reply",
    "contact.delete",
    "contact.export"
  ],
  "navEntries": [
    { "label": "Inbox", "path": "/m/contact-form/inbox", "icon": "<rect x=\"3\" y=\"5\" width=\"18\" height=\"14\" rx=\"2\"/><path d=\"m3 7 9 6 9-6\"/>", "permission": "contact.view" }
  ],
  "requiredEnvVars": [],
  "cookieCategories": [],
  "teardown": ["ContactSubmission", "ContactSubmissionReply"],
  "cronJobs": [
    { "path": "/api/m/contact-form/cron/retention", "schedule": "0 3 * * *" }
  ],
  "puckBlocks": [
    {
      "type": "ContactForm",
      "import": "./components/puck/ContactFormBlock",
      "component": "contactFormPuckComponent",
      "rscComponent": "contactFormPuckRscComponent"
    }
  ]
}
