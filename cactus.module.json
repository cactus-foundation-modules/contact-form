{
  "name": "contact-form",
  "version": "0.1.1",
  "tablePrefix": "cf_",
  "description": "A contact form that can be placed on any page via the Puck page builder, with per-form settings and an admin inbox.",
  "permissions": [
    "contact.view",
    "contact.reply",
    "contact.delete",
    "contact.export"
  ],
  "navEntries": [
    { "label": "Inbox", "path": "/m/contact-form/inbox", "icon": "✉️", "permission": "contact.view" }
  ],
  "requiredEnvVars": [],
  "cookieCategories": [],
  "teardown": ["ContactSubmission", "ContactSubmissionReply"],
  "puckBlocks": [
    {
      "type": "ContactForm",
      "import": "./components/puck/ContactFormBlock",
      "component": "contactFormPuckComponent",
      "rscComponent": "contactFormPuckRscComponent"
    }
  ]
}
